# =============================================================================
# Terraform Backend Configuration - S3 with Native Locking
# =============================================================================
#
# IMPORTANT: Copy this file to backend.tf and fill in your own values.
# DO NOT commit your actual backend.tf with real credentials to version control.
#

terraform {
  backend "s3" {
    bucket       = "YOUR_TFSTATE_BUCKET_NAME"  # e.g., "my-terraform-state-123456789012"
    key          = "YOUR_STATE_FILE_KEY"       # e.g., "nexacloud/prod/terraform.tfstate"
    region       = "us-east-1"
    use_lockfile = true
    encrypt      = true
  }
}
